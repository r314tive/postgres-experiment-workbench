EXPERIMENT_NAME="replica read-only utility smoke"
EXPERIMENT_TOPOLOGY="primary-replica"
EXPERIMENT_PG_CONFIG="default"
EXPERIMENT_PROFILE="smoke"
EXPERIMENT_PROFILE_SIZE="${EXPERIMENT_PROFILE_SIZE:-small}"
EXPERIMENT_PROFILE_SETUP=1
EXPERIMENT_PROFILE_RUN=0
EXPERIMENT_WORKLOAD_SPEC="topology/replica-readonly"
EXPERIMENT_METRICS=1
EXPERIMENT_METRICS_SAMPLES="${EXPERIMENT_METRICS_SAMPLES:-2}"
EXPERIMENT_SNAPSHOT="${EXPERIMENT_SNAPSHOT:-1}"
EXPERIMENT_ASSERT_SHELL='TOPOLOGY=primary-replica "$REPO_DIR/scripts/topology.sh" wait primary-replica >/dev/null; POSTGRES_HOST="${POSTGRES_REPLICA_HOST:-127.0.0.1}" POSTGRES_PORT="${POSTGRES_REPLICA_PORT:-55434}" "$REPO_DIR/scripts/wait_for_pg.sh" >/dev/null; "$REPO_DIR/scripts/psql_replica.sh" -At -c "SELECT pg_is_in_recovery()" | grep -q "^t$"'
