EXPERIMENT_NAME="constraints validation"
EXPERIMENT_TOPOLOGY="single"
EXPERIMENT_PG_CONFIG="default"
EXPERIMENT_PROFILE="constraints"
EXPERIMENT_PROFILE_SIZE="${EXPERIMENT_PROFILE_SIZE:-small}"
EXPERIMENT_PROFILE_SETUP=1
EXPERIMENT_PROFILE_RUN=0
EXPERIMENT_WORKLOAD_SPEC="profile/constraints-run"
EXPERIMENT_ASSERT_SQL="DO \$\$ BEGIN IF NOT EXISTS (SELECT 1 FROM pg_constraint WHERE connamespace = 'constraints_lab'::regnamespace AND conname = 'status_events_status_allowed' AND convalidated) THEN RAISE EXCEPTION 'expected validated status_events_status_allowed constraint'; END IF; END \$\$;"
EXPERIMENT_METRICS=1
EXPERIMENT_METRICS_SAMPLES="${EXPERIMENT_METRICS_SAMPLES:-2}"
EXPERIMENT_SNAPSHOT="${EXPERIMENT_SNAPSHOT:-1}"
