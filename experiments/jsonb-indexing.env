EXPERIMENT_NAME="jsonb indexing"
EXPERIMENT_TOPOLOGY="single"
EXPERIMENT_PG_CONFIG="default"
EXPERIMENT_PROFILE="jsonb"
EXPERIMENT_PROFILE_SIZE="${EXPERIMENT_PROFILE_SIZE:-small}"
EXPERIMENT_PROFILE_SETUP=1
EXPERIMENT_PROFILE_RUN=0
EXPERIMENT_WORKLOAD_SPEC="profile/jsonb-run"
EXPERIMENT_ASSERT_SQL="DO \$\$ BEGIN IF NOT EXISTS (SELECT 1 FROM pg_indexes WHERE schemaname = 'jsonb_lab' AND indexname = 'events_doc_path_gin_idx') THEN RAISE EXCEPTION 'expected jsonb GIN index'; END IF; IF (SELECT count(*) FROM jsonb_lab.events WHERE doc @> '{\"kind\": \"purchase\"}'::jsonb) = 0 THEN RAISE EXCEPTION 'expected purchase JSONB rows'; END IF; END \$\$;"
EXPERIMENT_METRICS=1
EXPERIMENT_METRICS_SAMPLES="${EXPERIMENT_METRICS_SAMPLES:-2}"
EXPERIMENT_SNAPSHOT="${EXPERIMENT_SNAPSHOT:-1}"
