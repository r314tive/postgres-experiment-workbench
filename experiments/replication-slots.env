EXPERIMENT_NAME="replication slot WAL retention"
EXPERIMENT_TOPOLOGY="primary-replica"
EXPERIMENT_PG_CONFIG="default"
EXPERIMENT_PROFILE="replication-slots"
EXPERIMENT_PROFILE_SIZE="${EXPERIMENT_PROFILE_SIZE:-small}"
EXPERIMENT_PROFILE_SETUP=1
EXPERIMENT_PROFILE_RUN=1
EXPERIMENT_WORKLOAD_SPEC="topology/replication-status"
EXPERIMENT_METRICS=1
EXPERIMENT_METRICS_SAMPLES="${EXPERIMENT_METRICS_SAMPLES:-2}"
EXPERIMENT_SNAPSHOT="${EXPERIMENT_SNAPSHOT:-1}"
EXPERIMENT_ASSERT_SQL="DO \$\$ BEGIN IF NOT EXISTS (SELECT 1 FROM pg_replication_slots WHERE slot_type = 'physical') THEN RAISE EXCEPTION 'expected physical replication slot'; END IF; END \$\$;"
