EXPERIMENT_NAME="multi-version upgrade smoke"
EXPERIMENT_TOPOLOGY="multi-version-upgrade"
EXPERIMENT_PG_CONFIG="default"
EXPERIMENT_PROFILE_SIZE="${EXPERIMENT_PROFILE_SIZE:-small}"
EXPERIMENT_DOCKER_RESET=1
EXPERIMENT_BEFORE_SHELL='"$REPO_DIR/scripts/psql_upgrade_old.sh" -v profile=smoke -v profile_size="${EXPERIMENT_PROFILE_SIZE:-small}" -v profile_seconds="${EXPERIMENT_PROFILE_SECONDS:-30}" -f "$REPO_DIR/profiles/smoke/sql/00_setup.sql"; "$REPO_DIR/scripts/psql_upgrade_old.sh" -v profile=smoke -v profile_size="${EXPERIMENT_PROFILE_SIZE:-small}" -v profile_seconds="${EXPERIMENT_PROFILE_SECONDS:-30}" -f "$REPO_DIR/profiles/smoke/sql/10_run.sql"'
EXPERIMENT_WORKLOAD_SPEC="topology/upgrade-dump-restore"
EXPERIMENT_AFTER_SHELL='"$REPO_DIR/scripts/run_workload.sh" run topology/upgrade-status'
EXPERIMENT_ASSERT_SHELL='old_count="$("$REPO_DIR/scripts/psql_upgrade_old.sh" -At -c "SELECT count(*) FROM smoke.items")"; new_count="$("$REPO_DIR/scripts/psql_upgrade_new.sh" -At -c "SELECT count(*) FROM smoke.items")"; old_num="$("$REPO_DIR/scripts/psql_upgrade_old.sh" -At -c "SELECT current_setting('\'server_version_num\'')::int")"; new_num="$("$REPO_DIR/scripts/psql_upgrade_new.sh" -At -c "SELECT current_setting('\'server_version_num\'')::int")"; test "$old_count" = "$new_count"; test "$new_count" = "10000"; test "$new_num" -gt "$old_num"'
EXPERIMENT_METRICS=0
EXPERIMENT_SNAPSHOT=0
