EXPERIMENT_NAME="PgBouncer smoke"
EXPERIMENT_TOPOLOGY="pgbouncer"
EXPERIMENT_PG_CONFIG="default"
EXPERIMENT_PROFILE="smoke"
EXPERIMENT_PROFILE_SIZE="${EXPERIMENT_PROFILE_SIZE:-small}"
EXPERIMENT_PROFILE_SETUP=1
EXPERIMENT_PROFILE_RUN=0
EXPERIMENT_WORKLOAD_SPEC="topology/pgbouncer-smoke"
EXPERIMENT_AFTER_SHELL='"$REPO_DIR/scripts/run_workload.sh" run topology/pgbouncer-admin'
EXPERIMENT_ASSERT_SHELL='TOPOLOGY=pgbouncer "$REPO_DIR/scripts/topology.sh" wait pgbouncer >/dev/null; POSTGRES_HOST="${PGBOUNCER_HOST:-127.0.0.1}" POSTGRES_PORT="${PGBOUNCER_PORT:-56432}" "$REPO_DIR/scripts/wait_for_pg.sh" >/dev/null; "$REPO_DIR/scripts/psql_pgbouncer.sh" -At -c "SELECT count(*) = 10000 FROM smoke.items" | grep -q "^t$"'
EXPERIMENT_METRICS=1
EXPERIMENT_METRICS_SAMPLES="${EXPERIMENT_METRICS_SAMPLES:-2}"
EXPERIMENT_SNAPSHOT="${EXPERIMENT_SNAPSHOT:-1}"
