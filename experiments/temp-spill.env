EXPERIMENT_NAME="temp-spill experiment"
EXPERIMENT_TOPOLOGY="single"
EXPERIMENT_PG_CONFIG="default"
EXPERIMENT_PROFILE="temp-spill"
EXPERIMENT_PROFILE_SIZE="${EXPERIMENT_PROFILE_SIZE:-small}"
EXPERIMENT_PROFILE_SETUP=1
EXPERIMENT_PROFILE_RUN=0
EXPERIMENT_WORKLOAD_SPEC="profile/temp-spill-run"
EXPERIMENT_ASSERT_SQL="SELECT count(*) > 0 FROM temp_spill.items;"
EXPERIMENT_ASSERT_SHELL='"$REPO_DIR/scripts/psql.sh" -At -c "SELECT temp_files > 0 FROM pg_stat_database WHERE datname = current_database()" | grep -q "^t$"'
EXPERIMENT_METRICS=1
EXPERIMENT_METRICS_SAMPLES="${EXPERIMENT_METRICS_SAMPLES:-2}"
EXPERIMENT_SNAPSHOT="${EXPERIMENT_SNAPSHOT:-1}"
