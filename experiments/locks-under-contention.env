EXPERIMENT_NAME="locks under contention"
EXPERIMENT_TOPOLOGY="single"
EXPERIMENT_PG_CONFIG="debug-logging"
EXPERIMENT_PROFILE="locks"
EXPERIMENT_PROFILE_SIZE="${EXPERIMENT_PROFILE_SIZE:-small}"
EXPERIMENT_PROFILE_SETUP=1
EXPERIMENT_BACKGROUND_SPECS="profile/locks-blocker"
EXPERIMENT_BACKGROUND_WARMUP=1
EXPERIMENT_PROFILE_SECONDS="${EXPERIMENT_PROFILE_SECONDS:-10}"
EXPERIMENT_WORKLOAD_SPEC="profile/locks-waiter"
EXPERIMENT_METRICS=1
EXPERIMENT_METRICS_SAMPLES=6
EXPERIMENT_ASSERT_SQL="DO \$\$ BEGIN IF (SELECT count(*) FROM locks.accounts) = 0 THEN RAISE EXCEPTION 'expected locks.accounts rows'; END IF; END \$\$;"
