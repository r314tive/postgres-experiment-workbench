EXPERIMENT_NAME="logical replication convergence"
EXPERIMENT_TOPOLOGY="logical-replication"
EXPERIMENT_PG_CONFIG="default"
EXPERIMENT_PROFILE="logical-replication"
EXPERIMENT_PROFILE_SIZE="${EXPERIMENT_PROFILE_SIZE:-small}"
EXPERIMENT_PROFILE_SETUP=1
EXPERIMENT_PROFILE_RUN=0
EXPERIMENT_BEFORE_SHELL='"$REPO_DIR/scripts/setup_logical_replication.sh"'
EXPERIMENT_WORKLOAD_SPEC="profile/logical-replication-run"
EXPERIMENT_AFTER_SHELL='"$REPO_DIR/scripts/run_workload.sh" run topology/logical-status'
EXPERIMENT_ASSERT_SHELL='TOPOLOGY=logical-replication "$REPO_DIR/scripts/topology.sh" wait logical-replication >/dev/null; POSTGRES_HOST="${POSTGRES_LOGICAL_SUBSCRIBER_HOST:-127.0.0.1}" POSTGRES_PORT="${POSTGRES_LOGICAL_SUBSCRIBER_PORT:-55435}" "$REPO_DIR/scripts/wait_for_pg.sh" >/dev/null; LOGICAL_REPLICATION_COMPARE_SQL="SELECT count(*), coalesce(sum(id), 0), coalesce(sum(length(payload)), 0), coalesce(sum(CASE WHEN updated_at IS NULL THEN 0 ELSE 1 END), 0) FROM logical_repl.events" "$REPO_DIR/scripts/wait_logical_replication.sh"'
EXPERIMENT_METRICS=1
EXPERIMENT_METRICS_SAMPLES="${EXPERIMENT_METRICS_SAMPLES:-2}"
EXPERIMENT_SNAPSHOT="${EXPERIMENT_SNAPSHOT:-1}"
