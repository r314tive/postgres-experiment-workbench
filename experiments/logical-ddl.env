EXPERIMENT_NAME="logical DDL boundary"
EXPERIMENT_TOPOLOGY="logical-replication"
EXPERIMENT_PG_CONFIG="default"
EXPERIMENT_PROFILE="logical-ddl"
EXPERIMENT_PROFILE_SIZE="${EXPERIMENT_PROFILE_SIZE:-small}"
EXPERIMENT_PROFILE_SETUP=1
EXPERIMENT_PROFILE_RUN=0
EXPERIMENT_BEFORE_SHELL='"$REPO_DIR/scripts/setup_logical_replication.sh"'
EXPERIMENT_WORKLOAD_SPEC="profile/logical-ddl-run"
EXPERIMENT_AFTER_SHELL='"$REPO_DIR/scripts/run_workload.sh" run topology/logical-status'
EXPERIMENT_ASSERT_SHELL='LOGICAL_REPLICATION_COMPARE_SQL="SELECT '\''events'\'' AS relation_name, count(*) AS rows_after_changes, coalesce(sum(id), 0) AS id_sum, coalesce(sum(length(payload)), 0) AS payload_bytes, coalesce(sum(length(ddl_marker)), 0) AS marker_bytes FROM logical_repl.events UNION ALL SELECT '\''ddl_notes'\'' AS relation_name, count(*) AS rows_after_changes, coalesce(sum(id), 0) AS id_sum, coalesce(sum(length(note)), 0) AS payload_bytes, 0 AS marker_bytes FROM logical_repl.ddl_notes ORDER BY relation_name" "$REPO_DIR/scripts/wait_logical_replication.sh"'
EXPERIMENT_METRICS=1
EXPERIMENT_METRICS_SAMPLES="${EXPERIMENT_METRICS_SAMPLES:-2}"
EXPERIMENT_SNAPSHOT="${EXPERIMENT_SNAPSHOT:-1}"
