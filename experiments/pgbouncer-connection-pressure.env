EXPERIMENT_NAME="PgBouncer connection pressure"
EXPERIMENT_TOPOLOGY="pgbouncer"
EXPERIMENT_PG_CONFIG="default"
EXPERIMENT_PROFILE="connection-pressure"
EXPERIMENT_PROFILE_SIZE="${EXPERIMENT_PROFILE_SIZE:-small}"
EXPERIMENT_PROFILE_SETUP=1
EXPERIMENT_PROFILE_RUN=0
EXPERIMENT_WORKLOAD_SPEC="topology/pgbouncer-connection-pressure"
EXPERIMENT_AFTER_SHELL='"$REPO_DIR/scripts/run_workload.sh" run topology/pgbouncer-admin'
EXPERIMENT_ASSERT_SHELL='"$REPO_DIR/scripts/psql_pgbouncer.sh" -At -c "SELECT count(*) > 0 FROM connection_pressure.events" | grep -q "^t$"'
EXPERIMENT_METRICS=1
EXPERIMENT_METRICS_SAMPLES="${EXPERIMENT_METRICS_SAMPLES:-2}"
EXPERIMENT_SNAPSHOT="${EXPERIMENT_SNAPSHOT:-1}"
