EXPERIMENT_NAME="pg_dump under WAL pressure"
EXPERIMENT_TOPOLOGY="single"
EXPERIMENT_PG_CONFIG="wal-heavy"
EXPERIMENT_PROFILE="smoke"
EXPERIMENT_PROFILE_SIZE="${EXPERIMENT_PROFILE_SIZE:-small}"
EXPERIMENT_PROFILE_SETUP=1
EXPERIMENT_BEFORE_SHELL='PROFILE_SIZE="${EXPERIMENT_PROFILE_SIZE:-small}" "$REPO_DIR/scripts/run_profile_sql.sh" wal-pressure 00_setup.sql'
EXPERIMENT_BACKGROUND_SPECS="profile/wal-pressure-run"
EXPERIMENT_BACKGROUND_WARMUP=1
EXPERIMENT_WORKLOAD_SPEC="utility/pg-dump-smoke"
EXPERIMENT_METRICS=1
EXPERIMENT_METRICS_SAMPLES=8
EXPERIMENT_ASSERT_SHELL='test -s "$REPO_DIR/logs/utility/pg-dump-smoke.sql"'
