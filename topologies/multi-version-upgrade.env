TOPOLOGY_NAME="multi-version-upgrade"
TOPOLOGY_DESCRIPTION="Old and new PostgreSQL versions for upgrade testing."
TOPOLOGY_SERVICES="postgres-old postgres-new"
TOPOLOGY_SOURCE_IMAGE="${POSTGRES_UPGRADE_OLD_IMAGE:-postgres:15-alpine}"
TOPOLOGY_TARGET_IMAGE="${POSTGRES_UPGRADE_NEW_IMAGE:-postgres:16-alpine}"
TOPOLOGY_SOURCE_PORT="${POSTGRES_UPGRADE_OLD_PORT:-55436}"
TOPOLOGY_TARGET_PORT="${POSTGRES_UPGRADE_NEW_PORT:-55437}"
