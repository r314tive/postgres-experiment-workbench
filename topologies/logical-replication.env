TOPOLOGY_PUBLICATION="${LOGICAL_REPLICATION_PUBLICATION:-workbench_logical_pub}"
TOPOLOGY_SUBSCRIPTION="${LOGICAL_REPLICATION_SUBSCRIPTION:-workbench_logical_sub}"
