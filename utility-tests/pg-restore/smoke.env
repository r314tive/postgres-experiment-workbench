UTILITY_TEST_NAME="pg_restore smoke schema"
UTILITY_TEST_PROFILE="smoke"
UTILITY_TEST_PROFILE_SIZE="${PROFILE_SIZE:-small}"
UTILITY_TEST_PROFILE_SECONDS="${PROFILE_SECONDS:-30}"
UTILITY_TEST_WORKLOAD_SPEC="utility/pg-restore-smoke"
UTILITY_TEST_METRICS="1"
UTILITY_TEST_METRICS_INTERVAL="${METRICS_INTERVAL:-1}"
UTILITY_TEST_METRICS_DURATION="${METRICS_DURATION:-30}"
UTILITY_TEST_EXPECT_FILES="logs/utility/pg-restore-smoke.dump.sql"
UTILITY_TEST_ASSERT_SQL="SELECT count(*) > 0 FROM restore_check.items;"
UTILITY_TEST_SCAN_PATHS="logs/utility"
UTILITY_TEST_NOTES="Dump the smoke schema, restore it into restore_check, and keep evidence under logs/utility."
