UTILITY_TEST_NAME="pg_dumpall under WAL pressure"
UTILITY_TEST_PROFILE="wal-pressure"
UTILITY_TEST_PROFILE_SIZE="${PROFILE_SIZE:-small}"
UTILITY_TEST_PROFILE_SECONDS="${PROFILE_SECONDS:-30}"
UTILITY_TEST_BACKGROUND_SPECS="profile/wal-pressure-run"
UTILITY_TEST_BACKGROUND_WARMUP="2"
UTILITY_TEST_BACKGROUND_WAIT="0"
UTILITY_TEST_WORKLOAD_SPEC="utility/pg-dumpall"
UTILITY_TEST_METRICS="1"
UTILITY_TEST_METRICS_INTERVAL="${METRICS_INTERVAL:-1}"
UTILITY_TEST_METRICS_DURATION="${METRICS_DURATION:-30}"
UTILITY_TEST_NOTES="Keep WAL-producing SQL active while pg_dumpall runs, then review workload logs and metrics CSV."
