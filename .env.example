POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=55433
POSTGRES_DB=pg_experiment_workbench
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_CONTAINER=postgres-experiment-workbench
POSTGRES_REPLICA_HOST=127.0.0.1
POSTGRES_REPLICA_PORT=55434
POSTGRES_REPLICA_CONTAINER=postgres-experiment-workbench-replica
POSTGRES_REPLICA_SLOT=workbench_replica_slot
POSTGRES_LOGICAL_SUBSCRIBER_HOST=127.0.0.1
POSTGRES_LOGICAL_SUBSCRIBER_PORT=55435
POSTGRES_LOGICAL_SUBSCRIBER_CONTAINER=postgres-experiment-workbench-logical-subscriber
ALLOW_NONLOCAL_PG=0
ALLOW_SYSTEM_DB=0

LOGICAL_REPLICATION_PUBLICATION=workbench_logical_pub
LOGICAL_REPLICATION_SUBSCRIPTION=workbench_logical_sub
LOGICAL_REPLICATION_SLOT=workbench_logical_slot
PGBOUNCER_HOST=127.0.0.1
PGBOUNCER_PORT=56432
PGBOUNCER_CONTAINER=postgres-experiment-workbench-pgbouncer
PGBOUNCER_IMAGE=edoburu/pgbouncer:v1.25.1-p0
PGBOUNCER_POOL_MODE=transaction
PGBOUNCER_AUTH_TYPE=plain
PGBOUNCER_MAX_CLIENT_CONN=100
PGBOUNCER_DEFAULT_POOL_SIZE=10
PGBOUNCER_MIN_POOL_SIZE=0
PGBOUNCER_RESERVE_POOL_SIZE=5
PGBOUNCER_IGNORE_STARTUP_PARAMETERS=extra_float_digits
PGBOUNCER_ADMIN_USERS=postgres
PGBOUNCER_STATS_USERS=postgres

TOPOLOGY=single
PROFILE=smoke
PROFILE_SIZE=small
PROFILE_SECONDS=30
PG_CONFIG=default
WORKLOAD_SQL=10_run.sql
WORKLOAD=wait-xacts
WORKLOAD_SPEC=workloads/sql/smoke-run.env
EXPERIMENT_SPEC=smoke
DATASET_SPEC=synthetic/items
DATASET_SIZE=small
DATASET_SEED=1
WORKLOAD_IMAGE=postgres:16-alpine
WORKLOAD_COMMAND=true

METRICS_INTERVAL=1
METRICS_DURATION=30
METRICS_SAMPLES=
METRICS_OUT=

PGBENCH_RESET=1
PGBENCH_INIT=1
PGBENCH_SCALE=1
PGBENCH_CLIENTS=2
PGBENCH_THREADS=1
PGBENCH_TIME=5

PG_REPO_URL=https://github.com/postgres/postgres.git
PG_REF=master
PG_CLONE_DEPTH=1
PG_SOURCE_KEEP_GOING=1

NOISIA_IMAGE=lesovsky/noisia:latest
NOISIA_PLATFORM=linux/amd64
NOISIA_DURATION=60
NOISIA_JOBS=2
NOISIA_WAIT_LOCKTIME_MIN=5
NOISIA_WAIT_LOCKTIME_MAX=15
NOISIA_TEMP_FILES_RATE=2
NOISIA_TEMP_FILES_SCALE_FACTOR=10
