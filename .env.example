POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=55433
POSTGRES_DB=pg_experiment_workbench
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_CONTAINER=postgres-experiment-workbench

PROFILE=smoke
PROFILE_SIZE=small
PROFILE_SECONDS=30
WORKLOAD_SQL=10_run.sql
WORKLOAD=wait-xacts
WORKLOAD_SPEC=workloads/sql/smoke-run.env
WORKLOAD_IMAGE=postgres:16-alpine
WORKLOAD_COMMAND=true

METRICS_INTERVAL=1
METRICS_DURATION=30
METRICS_SAMPLES=
METRICS_OUT=

PGBENCH_RESET=1
PGBENCH_INIT=1
PGBENCH_SCALE=1
PGBENCH_CLIENTS=2
PGBENCH_THREADS=1
PGBENCH_TIME=5

NOISIA_IMAGE=lesovsky/noisia:latest
NOISIA_PLATFORM=linux/amd64
NOISIA_DURATION=60
NOISIA_JOBS=2
NOISIA_WAIT_LOCKTIME_MIN=5
NOISIA_WAIT_LOCKTIME_MAX=15
NOISIA_TEMP_FILES_RATE=2
NOISIA_TEMP_FILES_SCALE_FACTOR=10
