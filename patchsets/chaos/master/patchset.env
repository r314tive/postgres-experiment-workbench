PATCHSET_NAME="chaos/master"
PATCHSET_DESCRIPTION="Default PostgreSQL master source-check patchset slot for chaos-style build flags."
PATCHSET_PG_REF="master"
PATCHSET_FILES=""
PATCHSET_ALLOW_EMPTY="1"
PATCHSET_CONFIGURE_ARGS="--enable-debug --enable-cassert --enable-tap-tests --enable-injection-points"
PATCHSET_BUILD_CFLAGS="-O0 -g -DWRITE_READ_PARSE_PLAN_TREES -DCOPY_PARSE_PLAN_TREES -DUSE_INJECTION_POINTS -DREALLOCATE_BITMAPSETS -DDISABLE_LEADER_PARTICIPATION"
PATCHSET_TEST_INITDB_EXTRA_OPTS="-c debug_copy_parse_plan_trees=on -c debug_write_read_parse_plan_trees=on -c debug_raw_expression_coverage_test=on"
