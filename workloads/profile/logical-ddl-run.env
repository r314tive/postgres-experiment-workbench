WORKLOAD_NAME="logical DDL profile direct run"
WORKLOAD_KIND="shell"
WORKLOAD_REQUIRES_POSTGRES=0
WORKLOAD_CMD='TOPOLOGY=logical-replication "$REPO_DIR/scripts/topology.sh" up logical-replication >/dev/null; "$REPO_DIR/scripts/run_profile_sql.sh" logical-ddl 10_run.sql; "$REPO_DIR/scripts/psql_logical_subscriber.sh" -f "$REPO_DIR/profiles/logical-ddl/sql/11_assert_subscriber_pre_repair.sql"; "$REPO_DIR/scripts/psql_logical_subscriber.sh" -f "$REPO_DIR/profiles/logical-ddl/sql/12_subscriber_repair.sql"; "$REPO_DIR/scripts/run_profile_sql.sh" logical-ddl 13_after_repair.sql'
