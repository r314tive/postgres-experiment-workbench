WORKLOAD_NAME="PostgreSQL source chaos-style make check"
WORKLOAD_KIND="pg-source-check"
PG_SOURCE_ACTION="${PG_SOURCE_ACTION:-run}"
PG_REF="${PG_REF:-master}"
PG_CHECK_TARGET="${PG_CHECK_TARGET:-check}"
PG_PATCH_DIR="${PG_PATCH_DIR:-patchsets/chaos/master}"
PG_CLONE_DEPTH="${PG_CLONE_DEPTH:-1}"
PG_CONFIGURE_ARGS="${PG_CONFIGURE_ARGS:---enable-debug --enable-cassert --enable-tap-tests --enable-injection-points}"
PG_BUILD_CFLAGS="${PG_BUILD_CFLAGS:--O0 -g -DWRITE_READ_PARSE_PLAN_TREES -DCOPY_PARSE_PLAN_TREES -DUSE_INJECTION_POINTS -DREALLOCATE_BITMAPSETS -DDISABLE_LEADER_PARTICIPATION}"
PG_TEST_INITDB_EXTRA_OPTS="${PG_TEST_INITDB_EXTRA_OPTS:--c debug_copy_parse_plan_trees=on -c debug_write_read_parse_plan_trees=on -c debug_raw_expression_coverage_test=on}"
PG_SOURCE_KEEP_GOING="${PG_SOURCE_KEEP_GOING:-1}"
