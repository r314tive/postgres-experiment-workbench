WORKLOAD_NAME="pg_dump smoke schema through Docker"
WORKLOAD_KIND="shell"
WORKLOAD_CMD='mkdir -p "$REPO_DIR/logs/utility" && docker compose --env-file "$ENV_PATH" exec -T postgres pg_dump -U "$PGUSER" -d "$PGDATABASE" -n smoke > "$REPO_DIR/logs/utility/pg-dump-smoke.sql" && test -s "$REPO_DIR/logs/utility/pg-dump-smoke.sql"'
