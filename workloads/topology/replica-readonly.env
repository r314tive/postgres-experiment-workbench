WORKLOAD_NAME="replica read-only query smoke"
WORKLOAD_KIND="shell"
WORKLOAD_REQUIRES_POSTGRES=0
WORKLOAD_CMD='TOPOLOGY=primary-replica "$REPO_DIR/scripts/topology.sh" up primary-replica >/dev/null; "$REPO_DIR/scripts/psql_replica.sh" -At -c "SELECT pg_is_in_recovery()" | grep -q "^t$"; "$REPO_DIR/scripts/psql_replica.sh" -c "SELECT count(*) AS smoke_rows FROM smoke.items;"'
