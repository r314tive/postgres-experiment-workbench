WORKLOAD_NAME="PgBouncer admin status"
WORKLOAD_KIND="shell"
WORKLOAD_REQUIRES_POSTGRES=0
WORKLOAD_CMD='TOPOLOGY=pgbouncer "$REPO_DIR/scripts/topology.sh" up pgbouncer >/dev/null; POSTGRES_DB=pgbouncer "$REPO_DIR/scripts/psql_pgbouncer.sh" -c "SHOW POOLS;"; POSTGRES_DB=pgbouncer "$REPO_DIR/scripts/psql_pgbouncer.sh" -c "SHOW STATS;"'
