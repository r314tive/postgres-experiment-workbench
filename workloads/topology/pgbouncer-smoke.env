WORKLOAD_NAME="PgBouncer smoke query"
WORKLOAD_KIND="shell"
WORKLOAD_CMD='TOPOLOGY=pgbouncer "$REPO_DIR/scripts/topology.sh" up pgbouncer >/dev/null; "$REPO_DIR/scripts/psql_pgbouncer.sh" -At -c "SELECT 1" | grep -q "^1$"; "$REPO_DIR/scripts/psql_pgbouncer.sh" -c "SELECT count(*) AS smoke_rows FROM smoke.items;"'
