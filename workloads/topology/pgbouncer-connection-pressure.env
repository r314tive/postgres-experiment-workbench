WORKLOAD_NAME="connection-pressure profile through PgBouncer"
WORKLOAD_KIND="shell"
WORKLOAD_REQUIRES_POSTGRES=0
WORKLOAD_CMD='TOPOLOGY=pgbouncer "$REPO_DIR/scripts/topology.sh" up pgbouncer >/dev/null; "$REPO_DIR/scripts/psql_pgbouncer.sh" -v profile="${PROFILE:-connection-pressure}" -v profile_size="${PROFILE_SIZE:-small}" -v profile_seconds="${PROFILE_SECONDS:-30}" -f "$REPO_DIR/profiles/connection-pressure/sql/10_run.sql"; POSTGRES_DB=pgbouncer "$REPO_DIR/scripts/psql_pgbouncer.sh" -c "SHOW POOLS;"'
