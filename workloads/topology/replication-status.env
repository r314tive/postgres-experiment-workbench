WORKLOAD_NAME="primary/replica replication status"
WORKLOAD_KIND="shell"
WORKLOAD_REQUIRES_POSTGRES=0
WORKLOAD_CMD='TOPOLOGY=primary-replica "$REPO_DIR/scripts/topology.sh" up primary-replica >/dev/null; "$REPO_DIR/scripts/psql.sh" -f "$REPO_DIR/sql/topology/primary_replication_status.sql"; "$REPO_DIR/scripts/psql_replica.sh" -f "$REPO_DIR/sql/topology/replica_recovery_status.sql"'
