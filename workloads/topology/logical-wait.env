WORKLOAD_NAME="logical replication convergence wait"
WORKLOAD_KIND="shell"
WORKLOAD_REQUIRES_POSTGRES=0
WORKLOAD_CMD='LOGICAL_REPLICATION_COMPARE_SQL="${LOGICAL_REPLICATION_COMPARE_SQL:-SELECT count(*), coalesce(sum(id), 0), coalesce(sum(length(payload)), 0), coalesce(sum(CASE WHEN updated_at IS NULL THEN 0 ELSE 1 END), 0) FROM logical_repl.events}" "$REPO_DIR/scripts/wait_logical_replication.sh"'
