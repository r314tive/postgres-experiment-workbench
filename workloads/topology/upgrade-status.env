WORKLOAD_NAME="multi-version upgrade status"
WORKLOAD_KIND="shell"
WORKLOAD_REQUIRES_POSTGRES=0
WORKLOAD_CMD='TOPOLOGY=multi-version-upgrade "$REPO_DIR/scripts/topology.sh" up multi-version-upgrade >/dev/null; "$REPO_DIR/scripts/psql_upgrade_old.sh" -f "$REPO_DIR/sql/topology/upgrade_version_status.sql"; "$REPO_DIR/scripts/psql_upgrade_new.sh" -f "$REPO_DIR/sql/topology/upgrade_version_status.sql"'
