WORKLOAD_NAME="logical replication status"
WORKLOAD_KIND="shell"
WORKLOAD_CMD='TOPOLOGY=logical-replication "$REPO_DIR/scripts/topology.sh" up logical-replication >/dev/null; "$REPO_DIR/scripts/psql.sh" -f "$REPO_DIR/sql/topology/logical_publisher_status.sql"; "$REPO_DIR/scripts/psql_logical_subscriber.sh" -f "$REPO_DIR/sql/topology/logical_subscriber_status.sql"'
