WORKLOAD_NAME="PgBouncer prepared statement diagnostic"
WORKLOAD_KIND="shell"
WORKLOAD_REQUIRES_POSTGRES=0
WORKLOAD_CMD='TOPOLOGY=pgbouncer "$REPO_DIR/scripts/topology.sh" up pgbouncer >/dev/null; "$REPO_DIR/scripts/psql_pgbouncer.sh" -v ON_ERROR_STOP=1 -c "PREPARE pgbouncer_probe AS SELECT count(*) FROM connection_pressure.events; EXECUTE pgbouncer_probe; DEALLOCATE pgbouncer_probe;"'
