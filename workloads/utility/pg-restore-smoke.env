WORKLOAD_NAME="pg_dump and pg_restore smoke schema into restore_check"
WORKLOAD_KIND="shell"
WORKLOAD_CMD='mkdir -p "$REPO_DIR/logs/utility" && docker compose --env-file "$ENV_PATH" exec -T postgres pg_dump -U "$PGUSER" -d "$PGDATABASE" -n smoke > "$REPO_DIR/logs/utility/pg-restore-smoke.dump.sql" && "$REPO_DIR/scripts/psql.sh" -c "DROP SCHEMA IF EXISTS restore_check CASCADE; CREATE SCHEMA restore_check;" && sed "s/^CREATE SCHEMA smoke;/CREATE SCHEMA IF NOT EXISTS restore_check;/; s/smoke\\./restore_check./g" "$REPO_DIR/logs/utility/pg-restore-smoke.dump.sql" | "$REPO_DIR/scripts/psql.sh"'
