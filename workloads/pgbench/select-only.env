WORKLOAD_NAME="pgbench select-only workload"
WORKLOAD_KIND="pgbench"
PGBENCH_RESET="${PGBENCH_RESET:-1}"
PGBENCH_INIT="${PGBENCH_INIT:-1}"
PGBENCH_SCALE="${PGBENCH_SCALE:-1}"
PGBENCH_CLIENTS="${PGBENCH_CLIENTS:-4}"
PGBENCH_THREADS="${PGBENCH_THREADS:-2}"
PGBENCH_TIME="${PGBENCH_TIME:-30}"
PGBENCH_MODE="select-only"
PGBENCH_EXTRA_ARGS="${PGBENCH_EXTRA_ARGS:- --aggregate-interval=5}"
